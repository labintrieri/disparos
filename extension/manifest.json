{
  "manifest_version": 3,
  "name": "Disparos Folha",
  "version": "2.0.0",
  "description": "Prepara mensagens de WhatsApp a partir de materias da Folha de S.Paulo",
  "permissions": [
    "activeTab",
    "clipboardWrite",
    "scripting",
    "tabs",
    "cookies"
  ],
  "host_permissions": [
    "https://*.folha.uol.com.br/*",
    "https://*.mlabs.io/*",
    "https://mla.bs/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Disparos Folha"
  },
  "background": {
    "service_worker": "background.js"
  }
}
