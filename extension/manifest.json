{
  "manifest_version": 3,
  "name": "Disparos Folha",
  "version": "1.1.0",
  "description": "Scanner de matérias da Folha de S.Paulo para WhatsApp",
  "permissions": [
    "activeTab",
    "clipboardWrite",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://*.folha.uol.com.br/*",
    "https://is.gd/*",
    "https://api.dub.co/*",
    "https://api.allorigins.win/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Disparos Folha"
  },
  "background": {
    "service_worker": "background.js"
  }
}
